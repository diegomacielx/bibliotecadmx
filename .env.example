VITE_FIREBASE_API_KEY=sua_api_key
VITE_FIREBASE_AUTH_DOMAIN=biblioteca-dmx.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=biblioteca-dmx
VITE_FIREBASE_STORAGE_BUCKET=biblioteca-dmx.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=571660956624
VITE_FIREBASE_APP_ID=1:571660956624:web:fc3d6e3fe402be7f70bfd5
VITE_APP_ID=dmx-exercicios-cloud
VITE_FUNCTIONS_REGION=us-central1

# E-mails transacionais (Resend) — configurar na Vercel
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Biblioteca DMX <noreply@seudominio.com.br>
# EMAIL_API_TOKEN=token_secreto_compartilhado
# VITE_EMAIL_API_TOKEN=token_secreto_compartilhado

# Firebase Admin (API /api/auth-email na Vercel) — uma das opções abaixo:
# Opção A: JSON completo da service account (recomendado)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"biblioteca-dmx",...}
# Opção B: campos separados
# FIREBASE_PROJECT_ID=biblioteca-dmx
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@biblioteca-dmx.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Caminho da coleção de exercícios (opcional — padrão: path legado artifacts/APP_ID/public/data/exercises)
# Coleção raiz alternativa: VITE_FIRESTORE_EXERCISES_PATH=exercises
# VITE_FIRESTORE_EXERCISES_PATH=artifacts/dmx-exercicios-cloud/public/data/exercises

# Base URL das capas 4K no GitHub (opcional — padrão: bibliotecadmx/main)
# VITE_GITHUB_COVER_BASE=https://raw.githubusercontent.com/diegomacielx/bibliotecadmx/main
